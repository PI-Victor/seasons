{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "seasons",
  "version": "0.1.0",
  "identifier": "io.cloudflavor.seasons",
  "build": {
    "beforeDevCommand": "CARGO_TARGET_DIR=target/trunk-dev trunk serve --dist dist-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "CARGO_TARGET_DIR=target/trunk-build trunk build --dist dist-build",
    "frontendDist": "../dist-build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "seasons",
        "width": 645,
        "minWidth": 645,
        "maxWidth": 645,
        "height": 932
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
